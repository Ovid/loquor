{
  // Extend the app project so compiler options never drift from the source
  // they exercise. Only the test-specific additions live here.
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "types": ["vite/client", "node", "vitest/globals"],
    "resolveJsonModule": true
  },
  // The base config excludes test files; that exclude is inherited via
  // `extends`, so we must clear it or our include below is filtered away.
  "exclude": [],
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.d.ts",
    "src/test",
    "vitest.config.ts"
  ]
}
